---
import ThemePicker from '../components/ThemePicker.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Software developer, bluegrass musician, and vintage computer collector." } = Astro.props;
const canonicalURL = new URL(Astro.url.pathname, Astro.site);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title === 'Larry Danna' ? title : `${title} — Larry Danna`}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;500;600&family=Instrument+Serif&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />

    <!--
      Theme init — runs synchronously before first paint to prevent a flash of
      the wrong theme. Mirrors the logic in ThemePicker.astro's <script>.
    -->
    <script is:inline>
      (function () {
        var stored = localStorage.getItem('ld-theme');
        if (!stored) {
          // Compute the season-aware auto theme
          var now     = new Date();
          var m       = now.getMonth() + 1;
          var d       = now.getDate();
          var jan1    = new Date(now.getFullYear(), 0, 1);
          var doy     = Math.ceil((now - jan1) / 86400000) + 1;
          var week    = Math.ceil(doy / 7);
          var season, ww;

          if ((m === 3 && d >= 20) || m === 4 || m === 5 || (m === 6 && d <= 20)) {
            season = 'spring'; ww = week - 12;
          } else if ((m === 6 && d >= 21) || m === 7 || m === 8 || (m === 9 && d <= 22)) {
            season = 'summer'; ww = week - 26;
          } else if ((m === 9 && d >= 23) || m === 10 || m === 11 || (m === 12 && d <= 20)) {
            season = 'fall'; ww = week - 39;
          } else {
            season = 'winter'; ww = week >= 52 ? week - 52 : week + 1;
          }

          var idx = Math.min(3, Math.max(0, Math.floor(ww / 3.5)));
          var themes = {
            spring: ['peach-blossom-dawn', 'april-rain-studio', 'clover-copper', 'wildflower-afternoon'],
            summer: ['heron-cove-dusk',    'firefly-hollow',    'salt-sunburn',  'thunderhead-indigo'],
            fall:   ['ember-birch',        'harvest-moon',      'ciderhouse-dusk','frost-before-frost'],
            winter: ['midnight-hearthside','frozen-pines',      'candlelit-library','ironclad-overcast'],
          };
          stored = themes[season][idx];
        }
        document.documentElement.dataset.theme = stored;
      })();
    </script>
  </head>
  <body>
    <header class="site-header">
      <div class="container header-inner">
        <a href="/" class="site-name">Larry Danna</a>
        <nav>
          <a href="/tools">Tools</a>
          <a href="/tips">Tips</a>
          <a href="/vintage">Vintage</a>
          <a href="/music">Music</a>
          <a href="/blog">Blog</a>
          <a href="/about">About</a>
        </nav>
        <ThemePicker />
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} Larry Danna</p>
      </div>
    </footer>
  </body>
</html>

<style is:global>
  @import '../styles/global.css';

  .site-header {
    border-bottom: 1px solid var(--border);
    padding: var(--space-sm) 0;
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 100;
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-md);
  }

  .site-name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    color: var(--text);
    text-decoration: none;
    white-space: nowrap;
  }

  .site-name:hover {
    color: var(--accent);
    text-decoration: none;
  }

  nav {
    display: flex;
    gap: var(--space-md);
    flex-wrap: wrap;
  }

  nav a {
    color: var(--muted);
    font-size: 0.9375rem;
    text-decoration: none;
  }

  nav a:hover,
  nav a[aria-current="page"] {
    color: var(--accent);
    text-decoration: none;
  }

  .site-footer {
    border-top: 1px solid var(--border);
    padding: var(--space-lg) 0;
    color: var(--muted);
    font-size: 0.875rem;
  }
</style>
