---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const songs = (await getCollection('music', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.localeCompare(a.data.date));
---

<BaseLayout title="Music" description="Song stories — AI-assisted folk and bluegrass compositions with lyrics, backstory, and audio.">
  <div class="section">
    <div class="container">
      <header class="music-header">
        <h1>Music</h1>
        <p class="lead">
          I'm an AI-assisted songwriter — Suno, mostly. Each piece here is a story:
          where it came from, what prompted it, and what Suno did with it.
          Lyrics, backstory, and audio on one page.
        </p>
        <a href="https://suno.com/@larrydanna" class="suno-link" target="_blank" rel="noopener">
          View full catalog on Suno →
        </a>
      </header>

      {songs.length === 0 ? (
        <p class="empty">Songs coming soon.</p>
      ) : (
        <div class="song-grid">
          {songs.map(song => (
            <a href={`/music/${song.id}`} class="song-card">
              <div class="card-meta">
                <time>{song.data.date}</time>
                <div class="tags">
                  {song.data.tags.slice(0, 3).map(tag => (
                    <span class="tag">{tag}</span>
                  ))}
                </div>
              </div>
              <h2>{song.data.title}</h2>
              <p class="card-description">{song.data.description}</p>
              <span class="read-link">Read the story →</span>
            </a>
          ))}
        </div>
      )}
    </div>
  </div>
</BaseLayout>

<style>
  .music-header {
    max-width: 680px;
    margin-bottom: var(--space-2xl);
  }

  h1 {
    font-family: var(--font-display);
    font-size: 3rem;
    margin-bottom: var(--space-md);
  }

  .lead {
    font-size: 1.125rem;
    line-height: 1.7;
    color: var(--muted);
    margin-bottom: var(--space-sm);
  }

  .suno-link {
    font-size: 0.875rem;
    color: var(--accent);
  }

  .song-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: var(--space-md);
  }

  .song-card {
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: var(--space-md);
    text-decoration: none;
    color: var(--text);
  }

  .song-card:hover {
    border-color: rgba(212, 134, 58, 0.4);
  }

  .card-meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .card-meta time {
    font-size: 0.8125rem;
    color: var(--muted);
  }

  .tags {
    display: flex;
    gap: 6px;
    flex-wrap: wrap;
  }

  .tag {
    background: rgba(212, 134, 58, 0.15);
    color: var(--accent);
    font-size: 0.75rem;
    font-weight: 500;
    padding: 2px 8px;
    border-radius: 4px;
  }

  h2 {
    font-family: var(--font-display);
    font-size: 1.5rem;
    font-weight: 400;
    margin: 0;
  }

  .card-description {
    font-size: 0.9375rem;
    color: var(--muted);
    line-height: 1.6;
    margin: 0;
    flex: 1;
  }

  .read-link {
    font-size: 0.875rem;
    color: var(--accent);
    margin-top: var(--space-xs);
  }

  .empty {
    color: var(--muted);
  }
</style>
