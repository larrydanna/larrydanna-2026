---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const tips = await getCollection('tips', ({ data }) => !data.draft);
  return tips.map(tip => ({ params: { slug: tip.id } }));
}

const { slug } = Astro.params;
const tip = await getEntry('tips', slug);
if (!tip) return Astro.redirect('/tips');

const { Content } = await render(tip);
---

<BaseLayout title={tip.data.title}>
  <div class="section">
    <div class="content-container">
      <nav class="breadcrumb">
        <a href="/tips">Tips</a>
        <span>/</span>
        <span>{tip.data.title}</span>
      </nav>

      <div class="tip-header">
        <div class="tip-meta">
          <span class="tip-lang">{tip.data.language}</span>
          <span class="tip-date">{tip.data.date}</span>
        </div>
        <h1>{tip.data.title}</h1>
        <div class="tip-tags">
          {tip.data.tags.map(tag => <a href={`/tips?tag=${tag}`} class="tag">{tag}</a>)}
        </div>
      </div>

      <div class="prose">
        <Content />
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--muted);
    font-size: 0.875rem;
    margin-bottom: var(--space-xl);
  }

  .breadcrumb a {
    color: var(--muted);
  }

  .breadcrumb a:hover {
    color: var(--accent);
  }

  .tip-header {
    border-left: 3px solid var(--accent);
    padding-left: var(--space-md);
    margin-bottom: var(--space-xl);
  }

  .tip-meta {
    display: flex;
    gap: var(--space-sm);
    margin-bottom: var(--space-sm);
  }

  .tip-lang {
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--accent);
  }

  .tip-date {
    font-size: 0.875rem;
    color: var(--muted);
  }

  h1 {
    font-size: 2rem;
    margin-bottom: var(--space-sm);
  }

  .tip-tags {
    display: flex;
    gap: var(--space-xs);
    flex-wrap: wrap;
  }
</style>
