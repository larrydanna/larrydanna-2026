---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Larry Danna" description="Software developer, bluegrass musician, and vintage computer collector.">
  <section class="hero section">
    <div class="container">
      <h1 class="hero-headline">I'm Larry (Danna) Collins Jr.</h1>
      <p class="hero-sub">
        Software developer (C#, SQL, .NET). Live bluegrass musician. Vintage computer collector.
        I build things that are useful, play things that are loud, and collect things that are old.
      </p>
      <div class="hero-links">
        <a href="/tools" class="btn btn-primary">See my tools</a>
        <a href="/about" class="btn btn-ghost">About me</a>
      </div>
    </div>
  </section>

  <section class="featured section-sm">
    <div class="container">
      <p class="section-label">Featured tool</p>
      <div class="card featured-tool">
        <div class="tool-meta">
          <span class="tag">Game</span>
          <span class="tag">Vanilla JS</span>
        </div>
        <h3>JeopardyJs</h3>
        <p>A fully playable Jeopardy game in the browser. Custom game files, multiple themes, Final Jeopardy. Built entirely in vanilla JavaScript.</p>
        <a href="/tools/jeopardy" class="btn btn-secondary">Play it</a>
      </div>
    </div>
  </section>

  <section class="section-links section-sm">
    <div class="container">
      <div class="link-grid">
        <a href="/tools" class="link-card">
          <h3>Tools</h3>
          <p>Interactive web demos I use myself. SQL helpers, regex testers, games, and more.</p>
        </a>
        <a href="/tips" class="link-card">
          <h3>Tips</h3>
          <p>Pro tips in C#, SQL, JavaScript, and 6502 assembly. Stack Overflow-style, searchable by tag.</p>
        </a>
        <a href="/vintage" class="link-card">
          <h3>Vintage</h3>
          <p>My Commodore 64 and vintage computer collection. Hardware history, personal notes, growing 6502 projects.</p>
        </a>
        <a href="/music" class="link-card">
          <h3>Music</h3>
          <p>Live bluegrass with friends. AI-assisted songwriting with Suno. Videos and tracks.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-headline {
    font-size: clamp(3rem, 8vw, 5rem);
    margin-bottom: var(--space-md);
  }

  .hero-sub {
    font-size: 1.125rem;
    color: var(--muted);
    max-width: 560px;
    margin-bottom: var(--space-lg);
    line-height: 1.7;
  }

  .hero-links {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .section-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin-bottom: var(--space-md);
  }

  .featured-tool {
    max-width: 480px;
  }

  .tool-meta {
    display: flex;
    gap: var(--space-xs);
    margin-bottom: var(--space-sm);
  }

  .featured-tool h3 {
    margin-bottom: var(--space-xs);
  }

  .featured-tool p {
    color: var(--muted);
    margin-bottom: var(--space-md);
  }

  .link-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-md);
  }

  .link-card {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: var(--space-md);
    text-decoration: none;
    color: var(--text);
  }

  .link-card:hover {
    border-color: rgba(212, 134, 58, 0.4);
    text-decoration: none;
  }

  .link-card h3 {
    color: var(--accent);
    margin-bottom: var(--space-xs);
  }

  .link-card p {
    color: var(--muted);
    font-size: 0.9375rem;
    margin: 0;
  }
</style>
