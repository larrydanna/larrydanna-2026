---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const recentPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.localeCompare(a.data.date))
  .slice(0, 3);
---

<BaseLayout title="Larry Danna" description="Software developer, bluegrass musician, and vintage computer collector.">
  <section class="hero section">
    <div class="container">
      <h1 class="hero-headline">I'm Larry (Danna) Collins Jr.</h1>
      <p class="hero-sub">
        Software developer (C#, SQL, .NET). Live bluegrass musician. Vintage computer collector.
        I build things that are useful, play things that are loud, and collect things that are old.
      </p>
      <div class="hero-links">
        <a href="/tools" class="btn btn-primary">See my tools</a>
        <a href="/about" class="btn btn-ghost">About me</a>
      </div>
    </div>
  </section>

  <section class="featured section-sm">
    <div class="container">
      <p class="section-label">Featured tools</p>
      <div class="featured-grid">
        <div class="card featured-tool">
          <div class="tool-meta">
            <span class="tag">Assembly</span>
            <span class="tag">6502</span>
            <span class="tag">Vanilla JS</span>
          </div>
          <h3>6502 Debugger</h3>
          <p>Write 6502 assembly in the browser and watch it run. Full assembler, step execution, live registers and flags, hex memory inspector. C64 compatible.</p>
          <a href="/6502-debugger/index.html" target="_blank" rel="noopener" class="btn btn-secondary">Open Debugger</a>
        </div>
        <div class="card featured-tool">
          <div class="tool-meta">
            <span class="tag">Productivity</span>
            <span class="tag">Kanban</span>
            <span class="tag">Vanilla JS</span>
          </div>
          <h3>Personal Kanban</h3>
          <p>Drag-and-drop cards across To Do, WIP, and Done. Multiple boards, editable columns, and JSON export.</p>
          <a href="/kanban/index.html" target="_blank" rel="noopener" class="btn btn-secondary">Open Board</a>
        </div>
        <div class="card featured-tool">
          <div class="tool-meta">
            <span class="tag">Productivity</span>
            <span class="tag">RPG</span>
            <span class="tag">Vanilla JS</span>
          </div>
          <h3>Dice Roller</h3>
          <p>Roll d4 through d100 with animated dice, custom modifiers, and a full session history. Built for tabletop RPG sessions.</p>
          <a href="/tools/diceroller" class="btn btn-secondary">Roll it</a>
        </div>
      </div>
    </div>
  </section>

  {recentPosts.length > 0 && (
    <section class="recent-posts section-sm">
      <div class="container">
        <div class="section-head">
          <p class="section-label">Recent posts</p>
          <a href="/blog" class="view-all">All posts →</a>
        </div>
        <div class="post-list">
          {recentPosts.map(post => (
            <article class="post-item">
              <div class="post-meta">
                <time>{post.data.date}</time>
                {post.data.tags.slice(0, 2).map(tag => (
                  <span class="tag">{tag}</span>
                ))}
              </div>
              <h3>
                <a href={`/blog/${post.id}`}>{post.data.title}</a>
              </h3>
              {post.data.description && (
                <p class="post-desc">{post.data.description}</p>
              )}
            </article>
          ))}
        </div>
      </div>
    </section>
  )}

  <section class="section-links section-sm">
    <div class="container">
      <div class="link-grid">
        <a href="/tools" class="link-card">
          <h3>Tools</h3>
          <p>Interactive web demos I use myself. SQL helpers, regex testers, games, and more.</p>
        </a>
        <a href="/tips" class="link-card">
          <h3>Tips</h3>
          <p>Pro tips in C#, SQL, JavaScript, and 6502 assembly. Stack Overflow-style, searchable by tag.</p>
        </a>
        <a href="/vintage" class="link-card">
          <h3>Vintage</h3>
          <p>My Commodore 64 and vintage computer collection. Hardware history, personal notes, growing 6502 projects.</p>
        </a>
        <a href="/music" class="link-card">
          <h3>Music</h3>
          <p>Live bluegrass with friends. AI-assisted songwriting with Suno. Videos and tracks.</p>
        </a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero-headline {
    font-size: clamp(3rem, 8vw, 5rem);
    margin-bottom: var(--space-md);
  }

  .hero-sub {
    font-size: 1.125rem;
    color: var(--muted);
    max-width: 560px;
    margin-bottom: var(--space-lg);
    line-height: 1.7;
  }

  .hero-links {
    display: flex;
    gap: var(--space-sm);
    flex-wrap: wrap;
  }

  .section-label {
    font-family: var(--font-body);
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--muted);
    margin-bottom: var(--space-md);
  }

  .featured-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-md);
  }

  .tool-meta {
    display: flex;
    gap: var(--space-xs);
    margin-bottom: var(--space-sm);
  }

  .featured-tool h3 {
    margin-bottom: var(--space-xs);
  }

  .featured-tool p {
    color: var(--muted);
    margin-bottom: var(--space-md);
  }

  /* ── Recent posts ──────────────────────────────────────── */
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: var(--space-md);
  }

  .section-head .section-label {
    margin-bottom: 0;
  }

  .view-all {
    font-size: 0.875rem;
    color: var(--accent);
    text-decoration: none;
  }

  .view-all:hover {
    text-decoration: underline;
  }

  .post-list {
    display: flex;
    flex-direction: column;
    border-top: 1px solid var(--border);
  }

  .post-item {
    padding: var(--space-md) 0;
    border-bottom: 1px solid var(--border);
  }

  .post-meta {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin-bottom: var(--space-xs);
  }

  .post-meta time {
    font-size: 0.8125rem;
    color: var(--muted);
  }

  .post-item h3 {
    font-size: 1.125rem;
    margin-bottom: var(--space-2xs);
  }

  .post-item h3 a {
    color: var(--text);
    text-decoration: none;
  }

  .post-item h3 a:hover {
    color: var(--accent);
  }

  .post-desc {
    color: var(--muted);
    font-size: 0.9375rem;
    margin: 0;
  }

  /* ── Link grid ─────────────────────────────────────────── */
  .link-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(240px, 1fr));
    gap: var(--space-md);
  }

  .link-card {
    display: block;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 8px;
    padding: var(--space-md);
    text-decoration: none;
    color: var(--text);
  }

  .link-card:hover {
    border-color: color-mix(in srgb, var(--accent) 40%, transparent);
    text-decoration: none;
  }

  .link-card h3 {
    color: var(--accent);
    margin-bottom: var(--space-xs);
  }

  .link-card p {
    color: var(--muted);
    font-size: 0.9375rem;
    margin: 0;
  }
</style>
