---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="JeopardyJs" description="A fully playable Jeopardy game in the browser. Built in vanilla JavaScript.">
  <div class="section-sm">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/tools">Tools</a>
        <span>/</span>
        <span>JeopardyJs</span>
      </nav>

      <div class="tool-header">
        <div class="tool-tags">
          <span class="tag">Game</span>
          <span class="tag">Vanilla JS</span>
        </div>
        <h1>JeopardyJs</h1>
        <p class="tool-description">
          A fully playable Jeopardy game in the browser. Multiple game files, multiple themes,
          Final Jeopardy, player management, and scoring. Zero external dependencies.
        </p>
      </div>
    </div>
  </div>

  <div class="game-frame-wrapper">
    <iframe
      src="/jeopardy/index.html"
      title="JeopardyJs game"
      id="jeopardy-frame"
      scrolling="no"
    ></iframe>
    <p class="frame-error" id="frame-error" style="display:none">
      Could not load game. <a href="/jeopardy/index.html" target="_blank">Open in new tab</a>
    </p>
  </div>
</BaseLayout>

<script>
  const frame = document.getElementById('jeopardy-frame') as HTMLIFrameElement;
  const error = document.getElementById('frame-error') as HTMLElement;

  // Auto-resize iframe to fit game content
  function resizeFrame() {
    try {
      const h = frame.contentWindow?.document?.body?.scrollHeight;
      if (h && h > 100) frame.style.height = h + 'px';
    } catch { /* cross-origin guard */ }
  }

  frame.addEventListener('load', () => {
    resizeFrame();
    // Re-check after game JS has rendered the board
    setTimeout(resizeFrame, 500);
    setTimeout(resizeFrame, 1500);
  });

  frame.addEventListener('error', () => {
    frame.style.display = 'none';
    error.style.display = 'block';
  });
</script>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--muted);
    font-size: 0.875rem;
    margin-bottom: var(--space-xl);
  }
  .breadcrumb a { color: var(--muted); }
  .breadcrumb a:hover { color: var(--accent); }

  .tool-header {
    max-width: var(--content-width);
    margin-bottom: var(--space-xl);
  }

  .tool-tags {
    display: flex;
    gap: var(--space-xs);
    margin-bottom: var(--space-sm);
  }

  h1 { margin-bottom: var(--space-sm); }

  .tool-description {
    color: var(--muted);
    font-size: 1rem;
    margin: 0;
  }

  .game-frame-wrapper {
    width: 100%;
    padding-bottom: var(--space-2xl);
  }

  iframe {
    width: 100%;
    min-height: 700px;
    border: none;
    display: block;
  }

  .frame-error {
    padding: var(--space-xl);
    text-align: center;
    color: var(--muted);
  }
</style>
