---
import BaseLayout from '../../layouts/BaseLayout.astro';
---

<BaseLayout title="Envelope Printer" description="Printable envelope template with editable address fields.">
  <div class="section-sm">
    <div class="container">
      <nav class="breadcrumb">
        <a href="/tools">Tools</a>
        <span>/</span>
        <span>Envelope Printer</span>
      </nav>
      <div class="tool-header">
        <div class="tool-tags">
          <span class="tag">Print</span>
          <span class="tag">Vanilla JS</span>
        </div>
        <h1>Envelope Printer</h1>
        <p class="tool-description">Fill in your addresses and print. Use your browser's print dialog — check landscape orientation.</p>
      </div>
    </div>
  </div>

  <div class="container tool-body">
    <div id="outer">
      <div id="from">
        <textarea id="txtFrom">Larry Danna
100 Cooper Place West
Dayton, Ohio 45402</textarea>
      </div>
      <div id="to">
        <textarea id="txtTo">Mr John Doe
1234 Main St
PO Box 98765
Dayton, Ohio 45403</textarea>
      </div>
    </div>

    <div id="notes">
      <p>Print using <strong>Ctrl+P</strong> / browser print dialog. Set orientation to <strong>Landscape</strong>.</p>
    </div>
  </div>
</BaseLayout>

<style>
  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    color: var(--muted);
    font-size: 0.875rem;
    margin-bottom: var(--space-xl);
  }
  .breadcrumb a { color: var(--muted); }
  .breadcrumb a:hover { color: var(--accent); }

  .tool-header { max-width: var(--content-width); margin-bottom: var(--space-xl); }
  .tool-tags { display: flex; gap: var(--space-xs); margin-bottom: var(--space-sm); }
  h1 { margin-bottom: var(--space-xs); }
  .tool-description { color: var(--muted); margin: 0; }

  .tool-body { padding-bottom: var(--space-2xl); }

  #outer {
    border: 1px solid var(--border);
    width: 9.25in;
    height: 3.0875in;
    position: relative;
    background: white;
    color: black;
  }

  #from { position: absolute; top: 0.3in; left: 0.3in; }
  #to   { position: absolute; top: 0.8in; left: 4in; }

  #txtFrom, #txtTo {
    font-family: Helvetica, Arial, sans-serif;
    font-weight: bold;
    border: 1px dashed #ccc;
    resize: none;
    background: white;
    color: black;
    padding: 4px;
  }
  #txtFrom { font-size: 1rem; width: 250px; height: 80px; }
  #txtTo   { font-size: 1.5rem; width: 480px; height: 140px; }

  #notes {
    margin-top: var(--space-md);
    color: var(--muted);
    font-size: 0.9375rem;
  }

  @media print {
    #notes { display: none; }
    #outer { border: none; }
    #txtFrom, #txtTo { border: none; }
  }
</style>
